        "measures": [
          {
            "name": "Total Repasses",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "SUM(amostra_bolsa[VALOR PARCELA])",
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "aa842e07-52da-4e1d-978a-1b31d21df743"
          },
          {
            "name": "Total Beneficiarios",
            "expression": "COUNTROWS(amostra_bolsa)",
            "formatString": "0",
            "lineageTag": "885bde3c-f8b2-4b50-a34e-060e7d462978"
          },
          {
            "name": "Ticket Medio",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "DIVIDE([Total Repasses], [Total Beneficiarios])",
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "8701e228-3839-4b89-a5e9-effe6aea8963"
          },
          {
            "name": "Total Municipios",
            "expression": "DISTINCTCOUNT(amostra_bolsa[CÓDIGO MUNICÍPIO SIAFI])",
            "formatString": "0",
            "lineageTag": "69487b16-c4f5-4b81-b7c5-3b489cbe124f"
          }
        ],
        "partitions": [
          {
            "name": "amostra_bolsa",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = Csv.Document(File.Contents(\"C:\\Users\\davimorais\\Downloads\\amostra_bolsa.csv\"),[Delimiter=\",\", Columns=8, Encoding=65001, QuoteStyle=QuoteStyle.None]),",
                "    #\"Cabeçalhos Promovidos\" = Table.PromoteHeaders(Fonte, [PromoteAllScalars=true]),",
                "    #\"Tipo Alterado\" = Table.TransformColumnTypes(#\"Cabeçalhos Promovidos\",{{\"MÊS COMPETÊNCIA\", Int64.Type}, {\"UF\", type text}, {\"CÓDIGO MUNICÍPIO SIAFI\", Int64.Type}, {\"NOME MUNICÍPIO\", type text}, {\"CPF FAVORECIDO\", type text}, {\"NIS FAVORECIDO\", Int64.Type}, {\"NOME FAVORECIDO\", type text}, {\"VALOR PARCELA\", Currency.Type}}),",
                "    #\"Coluna Duplicada\" = Table.DuplicateColumn(#\"Tipo Alterado\", \"MÊS COMPETÊNCIA\", \"MÊS COMPETÊNCIA - Copiar\"),",
                "    #\"Coluna Duplicada1\" = Table.DuplicateColumn(#\"Coluna Duplicada\", \"MÊS COMPETÊNCIA\", \"MÊS COMPETÊNCIA - Copiar.1\"),",
                "    #\"Primeiros caracteres extraídos\" = Table.TransformColumns(#\"Coluna Duplicada1\", {{\"MÊS COMPETÊNCIA - Copiar\", each Text.Start(Text.From(_, \"pt-BR\"), 4), type text}}),",
                "    #\"Últimos caracteres extraídos\" = Table.TransformColumns(#\"Primeiros caracteres extraídos\", {{\"MÊS COMPETÊNCIA - Copiar.1\", each Text.End(Text.From(_, \"pt-BR\"), 2), type text}}),",
                "    #\"Colunas Renomeadas\" = Table.RenameColumns(#\"Últimos caracteres extraídos\",{{\"MÊS COMPETÊNCIA - Copiar\", \"ANO\"}, {\"MÊS COMPETÊNCIA - Copiar.1\", \"MÊS\"}})",
                "in",
                "    #\"Colunas Renomeadas\""
              ],
              "type": "m"
            }
          }
        ]
