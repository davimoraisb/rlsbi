        "lineageTag": "b583e548-3cf6-45d3-829f-033fdab89a0d",
        "partitions": [
          {
            "name": "dim_usuarios_rls",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = Table.FromRows(",
                "        {",
                "            {\"gestor.norte@ministerio.br\", \"Norte\"},",
                "            {\"gestor.nordeste@ministerio.br\", \"Nordeste\"},",
                "            {\"gestor.centroeste@ministerio.br\", \"Centro-Oeste\"},",
                "            {\"gestor.sudeste@ministerio.br\", \"Sudeste\"},",
                "            {\"gestor.sul@ministerio.br\", \"Sul\"}",
                "        },",
                "        {\"email_usuario\", \"regiao_permitida\"}",
                "    ),",
                "    TipoAlterado = Table.TransformColumnTypes(",
                "        Fonte,",
                "        {",
                "            {\"email_usuario\", type text},",
                "            {\"regiao_permitida\", type text}",
                "        }",
                "    )",
                "in",
                "    TipoAlterado"
              ],
              "type": "m"
            }
          }
        ]
      },
